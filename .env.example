# API Configuration
# Choose one of the following API providers

# === Option 1: OpenAI ===
OPENAI_API_KEY=sk-your-key-here
API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

HF_TOKEN=hf_your-token-here

# === Option 2: Groq (faster and cheaper) ===
# GROQ_API_KEY=gsk_your-key-here
# API_BASE_URL=https://api.groq.com/openai/v1
# MODEL_NAME=mixtral-8x7b-32768

# === Option 3: Hugging Face ===
# HF_TOKEN=hf_your-token-here
# API_BASE_URL=https://api-inference.huggingface.co/v1
# MODEL_NAME=meta-llama/Llama-2-70b

# === Option 4: Local Ollama ===
# API_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=local
# MODEL_NAME=llama2

# Optional settings
TEMPERATURE=0.5
MAX_TOKENS=200

# === Environment API Configuration ===
# Leave unset or commented to use local environment directly (no Docker needed)
# Set this to make inference.py connect to the Docker API container
# Examples:
#   - Local Docker: http://localhost:7860
#   - Hugging Face Space: https://username-spacename.hf.space
ENVIRONMENT_BASE_URL=http://localhost:7860
